{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "include": [
    "caffeine-build/cmake/presets/base.json"
  ],
  "configurePresets": [
    {
      "name": "unit-tests-gtest",
      "inherits": "base-unit-tests-gtest"
    },
    {
      "name": "ci-all-sources",
      "displayName": "Universe CI Target (All Sources)",
      "inherits": "base-common",
      "binaryDir": "${sourceDir}/build/ci-all-sources"
    }
  ],
  "testPresets": [
    {
      "name": "unit-tests-gtest",
      "configurePreset": "unit-tests-gtest",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}